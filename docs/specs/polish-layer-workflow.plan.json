      "resumable-handoffs",
      "multi-surface-fanout",
      "planned-fanout",
      "adversarial-verification",
      "human-gates"
    ],
    "downgrade_target": null,
    "reason": "The FigOps polish layer spans docs, MCP schemas, renderer behavior, fixtures, tests, reviews, and release readiness, so it needs staged handoffs and independent verification."
  },
  "objective": "Deliver a journal-compliant FigOps polish layer that improves visual finish without weakening reproducibility or journal-format constraints, with documentation, implementation, review, verification, second review, and release-ready evidence.",
  "surfaces": [
    {
      "id": "figops-repo",
