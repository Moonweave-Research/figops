      "verification-receipt.md",
      "final-review.md"
    ],
    "invalidators": [
      "branch changes from origin/main",
      "schema or renderer files modified outside this workflow",
      "test suite baseline changes",
      "user changes priority order"
    ],
    "restart_points": [
      "p1-document-spec",
      "p2-gap-fixtures",
      "p3-implement-next-wave",
      "p5-verification",
      "p7-release-ready"
    ]
  },
  "execution_path": {
    "mode": "subagent-plan",
    "consumer": "codex-agent",
    "first_slice": {
      "instruction": "Create the documentation-first FigOps polish layer spec and machine-readable workflow plan in docs/specs without implementation edits.",
      "inputs": [
        "repository path",
        "user objective",
        "prior polish review",
        "current git status"
      ],
      "expected_output": "docs/specs/polish-layer-finalization.md and docs/specs/polish-layer-workflow.plan.json with validation evidence",
      "completion_check": "python -m json.tool docs/specs/polish-layer-workflow.plan.json succeeds and the spec contains research, product position, architecture, execution model, safety gates, fixtures, and release plan",
      "forbidden_actions": [
        "source code edits",
        "test edits",
        "dependency changes",
        "release publication"
      ]
    },
    "first_wave": {
      "id": "w1-documentation",
      "concurrency_cap": 1,
      "slices": [
        {
          "id": "s1-doc-spec",
          "instruction": "Author docs/specs/polish-layer-finalization.md from the current repo audit and write docs/specs/polish-layer-workflow.plan.json as the source of truth.",
          "inputs": [
            "repository path",
            "prior polish review",
            "workflow schema"
          ],
          "expected_output": "Spec and plan files are present and internally consistent.",
          "completion_check": "Both files validate with json.tool and section grep checks.",
          "forbidden_actions": [
            "source code edits",
            "test edits",
            "dependency changes",
            "release publication"
          ]
        }
      ],
      "entry_gate": "Repository is on a clean or workflow-owned dirty state and the user requested documentation-first execution.",
      "exit_gate": "Documentation receipt exists with validation commands and no source edits.",
      "fan_in": "No fan-in needed for the first documentation slice."
    },
    "waves": [
      {
        "id": "w2-audit-fixtures",
        "depends_on": [
          "w1-documentation"
        ],
        "concurrency_cap": 2,
        "slices": [
          "s2-gap-audit",
          "s3-fixture-manifest"
        ],
        "entry_gate": "Prior receipt is verified and documentation exit gate passed.",
        "exit_gate": "Audit report and fixture manifest identify one bounded implementation slice."
      },
      {
        "id": "w3-implementation",
        "depends_on": [
          "w2-audit-fixtures"
