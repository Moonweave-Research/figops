    {
      "id": "docs-surface",
      "kind": "document",
      "locator": "docs/specs, docs/tools.md, README.md, CHANGELOG.md",
      "access_mode": "write-approved"
    },
    {
      "id": "pnu-reference-figures",
      "kind": "data-source",
      "locator": "/Users/choemun-yeong/Library/CloudStorage/GoogleDrive-choimoonyoung3631@gmail.com/My Drive/Research/03_Pusan_Sample/results/figures/pnu_260616",
      "access_mode": "read-only"
    }
  ],
  "assumptions": [
    {
      "claim": "The current branch is clean enough to start a focused polish workflow.",
      "verification": "Run git status --short --branch before each wave and stop if unrelated dirty work appears."
    },
    {
      "claim": "Polish improvements must remain journal-track compliant rather than adding arbitrary custom plotting freedom.",
      "verification": "Every implementation slice must run targeted journal/theme tests and preserve compliance diagnostics."
    },
    {
      "claim": "The highest leverage next implementation is bounded legend/axis polish, not a new plotting engine or a repeat of completed schema/series/callout work.",
      "verification": "Map each planned change to existing renderer or MCP gaps before editing and reject changes that create a parallel API or duplicate shipped PRs #196-#198."
    },
    {
      "claim": "Visual quality must be tested through artifacts, not only argument normalization.",
      "verification": "Each feature slice needs a schema or normalization test plus a render or diagnostics test proving the value reaches figure output."
    }
  ],
  "patterns": [
    "Sequential",
    "Parallel Fan-Out / Fan-In",
    "Adversarial Verify",
    "Human Gate",
    "Resume And Cache"
  ],
  "phases": [
    {
