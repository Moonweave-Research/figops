  "parallelism": {
    "shape": "hybrid",
    "concurrency_cap": 3,
    "fan_in_rule": "Fan in after p2 gap audit and again after p6 final review; implementation waves stay sequential unless selected slices touch disjoint files.",
    "barriers": [
      "p1 spec before implementation",
      "p2 audit before selected slice",
      "p5 verification before final review",
      "user approval before public release"
    ]
  },
  "verification": [
    {
      "claim_or_output": "Spec matches repo reality",
      "falsifier": "Find a claimed capability absent from current source or a source capability omitted from P1 scope",
      "evidence_required": [
        "file:line citations",
        "git status",
        "spec checklist"
      ]
    },
    {
      "claim_or_output": "Implementation reaches MCP users",
      "falsifier": "Feature only changes renderer internals without schema, normalization, docs, or MCP route coverage",
      "evidence_required": [
        "schema diff",
        "normalization tests",
        "docs/tools or tool doc evidence"
      ]
    },
    {
      "claim_or_output": "Implementation reaches pixels or diagnostics",
      "falsifier": "Tests only inspect Python objects and do not render or inspect output artifacts where visual behavior matters",
      "evidence_required": [
        "render test",
        "artifact manifest",
        "geometry diagnostics receipt"
      ]
    },
    {
      "claim_or_output": "Journal compliance remains intact",
      "falsifier": "New style controls bypass journal_theme constraints or reduce compliance diagnostics",
      "evidence_required": [
        "journal theme tests",
        "targeted renderer tests",
        "review note"
      ]
    },
    {
      "claim_or_output": "Final completion is release ready",
      "falsifier": "Unresolved high severity review item, failed targeted test, dirty generated files, or missing changelog note",
      "evidence_required": [
        "final review",
        "test log",
        "git diff summary",
        "release checklist"
      ]
    }
  ],
  "risk_gates": [
    {
      "trigger": "write actions in repository",
      "safe_default": "stop before write actions and ask for approval",
      "requires_user_approval": true
    },
    {
      "trigger": "shell commands for tests and generation",
      "safe_default": "stop before shell commands and ask for approval",
      "requires_user_approval": true
    },
    {
      "trigger": "new dependency introduction",
      "safe_default": "do not add dependency without approval",
      "requires_user_approval": true
    },
    {
      "trigger": "public release publication",
      "safe_default": "stop before public release and ask for approval",
      "requires_user_approval": true
    },
    {
      "trigger": "history rewrite or force push",
      "safe_default": "do not rewrite history without approval",
      "requires_user_approval": true
    }
  ],
  "budget": {
    "max_agents": 6,
    "max_rounds": 7,
    "max_retries": 2,
    "time_box": "One focused feature cycle before PR; stop after two review-fix loops without new high severity findings.",
    "file_touch_limit": "Prefer under 12 source files per implementation wave; docs and tests may add focused fixtures."
  },
  "resume": {
    "cacheable_outputs": [
      "docs/specs/polish-layer-current-state-inventory.md",
      "docs/specs/polish-layer-finalization.md",
      "docs/specs/polish-layer-workflow.plan.json",
