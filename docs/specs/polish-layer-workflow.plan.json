    {
      "id": "p4-first-review",
      "name": "First independent review",
      "entry_criteria": [
        "p3 patch and test log exist"
      ],
      "exit_criteria": [
        "Findings are confirmed, refuted, or fixed",
        "No unresolved high severity regression remains"
