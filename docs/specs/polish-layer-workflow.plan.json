    {
      "id": "p5-verification",
      "name": "Verification and visual evidence",
      "entry_criteria": [
        "p4 high severity issues resolved or explicitly deferred"
      ],
      "exit_criteria": [
        "Schema, normalization, render, and diagnostics checks pass",
        "Any skipped validation is documented"
