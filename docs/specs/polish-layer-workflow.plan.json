      "worker_ids": [
        "verifier"
      ],
      "outputs": [
        "verification-receipt.md",
        "full-test-log.txt",
        "render-artifacts-manifest.json"
      ]
    },
    {
      "id": "p6-final-review",
      "name": "Second adversarial review",
      "entry_criteria": [
        "p5 verification receipt exists"
      ],
      "exit_criteria": [
        "Reviewer fails to refute completion claims",
        "Release blockers list is empty or gated"
      ],
      "depends_on": [
        "p5-verification"
      ],
      "worker_ids": [
        "reviewer",
        "lead"
      ],
      "outputs": [
        "final-review.md"
      ]
    },
    {
      "id": "p7-release-ready",
      "name": "Release readiness and handoff",
      "entry_criteria": [
        "p6 final review passes"
      ],
      "exit_criteria": [
        "Changelog or release notes drafted",
        "PR body and merge checklist are ready",
        "Public release remains gated"
      ],
      "depends_on": [
        "p6-final-review"
      ],
      "worker_ids": [
        "lead"
      ],
      "outputs": [
        "release-readiness.md",
        "pr-body.md"
      ]
    }
  ],
